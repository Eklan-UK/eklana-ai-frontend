# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment — never commit files with real secrets.
# Track only `.env.example` (template); all other env variants stay local.
.env
.env.*
!.env.example

# Private keys, certs, and cloud provider service-account JSON
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa
*firebase-adminsdk*.json
*-adminsdk-*.json
**/credentials.json
**/client_secret*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA files
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/fallback-*.js
/public/fallback-*.js.map
