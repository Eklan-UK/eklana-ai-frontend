# =============================================================================
# Eklan / Eklana AI — environment template
# Copy to `.env` or `.env.local` and replace placeholder values.
# `.env` and `.env.local` are gitignored; commit `.env.example` only.
# =============================================================================

# --- Core app URLs (local dev often uses http://localhost:3000) -------------
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: explicit Better Auth base URL (defaults from NEXT_PUBLIC_API_URL / Vercel)
BETTER_AUTH_URL=http://localhost:3000

# --- Vercel: staging vs production (avoid login redirect loops) ----------------
# Use ONE canonical origin per deployment — the URL users open in the browser:
#   Production:  NEXT_PUBLIC_API_URL=https://app.eklan.ai
#                BETTER_AUTH_URL=https://app.eklan.ai
#                NEXT_PUBLIC_APP_URL=https://app.eklan.ai
#   Staging:     NEXT_PUBLIC_API_URL=https://staging.eklan.ai
#                BETTER_AUTH_URL=https://staging.eklan.ai
#                NEXT_PUBLIC_APP_URL=https://staging.eklan.ai
# Do not point staging’s NEXT_PUBLIC_API_URL at production (or vice versa) unless you
# intentionally split UI/API; this app’s axios client uses same-origin /api/v1.
#
# Verify in DevTools → Application → Cookies on that host after login:
#   Name: better-auth.session_token (Better Auth default cookie prefix)

# --- Database ---------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/your-database-name

# --- Auth secrets (use long random strings in production) -------------------
BETTER_AUTH_SECRET=replace-with-long-random-secret
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-secret
# Optional token lifetimes (if your app reads these)
ACCESS_TOKEN_EXPIRY=
REFRESH_TOKEN_EXPIRY=

# --- Troubleshooting: “kicked to login every click” --------------------------
# 1) Confirm /api/v1 requests go to the SAME host as the page (Network tab).
# 2) Inspect failing responses: repeated 401 → see axios interceptor in src/lib/api/axios.ts.
# 3) If session is empty, fix URLs/secrets above before changing middleware (Edge cannot run Better Auth DB session).

# --- CORS / deployment ------------------------------------------------------
# Comma-separated extra browser origins for Better Auth (trustedOrigins).
# Canonical origins (localhost, app.eklan.ai, staging.eklan.ai) are always merged; use this for previews or extra domains.
# Example (Vercel Preview UI): WHITELIST_ORIGINS=https://your-app-git-branch-team.vercel.app
WHITELIST_ORIGINS=
# Set automatically on Vercel; optional override for client
NEXT_PUBLIC_VERCEL_URL=

# --- Super admin seed / bootstrap (see src/lib/api/config.ts) ---------------
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=
SUPER_ADMIN_LAST_NAME=

# --- OAuth (optional) --------------------------------------------------------
# Better Auth Google sign-in only (openid / profile / email). Register redirect:
#   {BETTER_AUTH_URL}/api/v1/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Tutor Google Calendar connect (separate OAuth client). Register redirect:
#   {BETTER_AUTH_URL}/api/v1/tutor/google-calendar/callback
# Scopes: calendar.events, offline refresh for scheduling.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Multiline PEM often loaded differently in production; set as needed
APPLE_PRIVATE_KEY=

# --- Email: SMTP (optional) -------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# --- Email: Gmail alternative (optional) ----------------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=

EMAIL_FROM=
# Used in some API routes / web-push mailto
SUPPORT_EMAIL=

# --- Firebase (client — NEXT_PUBLIC_* are exposed to the browser) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Firebase Admin (server — JSON string of service account) ---------------
FIREBASE_SERVICE_ACCOUNT=

# --- Web Push / VAPID (optional) -------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Speechace (server API routes use SPEECHACE_*; set your real key) -------
SPEECHACE_API_KEY=
SPEECHACE_API_ENDPOINT=https://api.speechace.co
# Client-side direct service (if used)
NEXT_PUBLIC_SPEECHACE_API_KEY=
NEXT_PUBLIC_SPEECHACE_API_ENDPOINT=https://api.speechace.co

# --- Google Gemini (optional) ----------------------------------------------
GEMINI_API_KEY=

# --- ElevenLabs TTS (optional) ----------------------------------------------
ELEVEN_LABS_API_KEY=
ELEVENLABS_API_KEY=
ELEVEN_LABS_DEFAULT_VOICE_ID=
ELEVENLABS_DEFAULT_VOICE_ID=

# --- Cloudinary (optional) --------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Classes / video providers (see CLASSES-IMPLEMENTATION.md at repo root) ----
# Default IANA timezone for schedule buckets if not set per class (optional)
CLASSES_DEFAULT_TIMEZONE=UTC
# Google Calendar API (optional — Meet links / calendar events via service account JSON)
GOOGLE_CALENDAR_CREDENTIALS_JSON=
# Tutor calendar OAuth uses GOOGLE_CALENDAR_CLIENT_ID / GOOGLE_CALENDAR_CLIENT_SECRET above.
# Zoom Server-to-Server OAuth or OAuth app (optional — Phase 6)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# --- Class session reminders (Phase 7 — cron / external scheduler) ---------
# GET /api/v1/cron/class-session-reminders with Authorization: Bearer <secret>
CLASS_REMINDER_CRON_SECRET=

# --- Misc -------------------------------------------------------------------
BOOK_CALL_EMAIL=
LOG_LEVEL=info
